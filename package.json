{
  "name": "arkiv-search-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "shared",
    "indexer",
    "server",
    "client"
  ],
  "scripts": {
    "fetch": "pnpm --filter @arkiv-search/indexer run fetch",
    "chunk": "pnpm --filter @arkiv-search/indexer run chunk",
    "embed": "pnpm --filter @arkiv-search/indexer run embed",
    "centroids": "pnpm --filter @arkiv-search/indexer run centroids",
    "assign": "pnpm --filter @arkiv-search/indexer run assign",
    "eval": "pnpm --filter @arkiv-search/indexer run eval",
    "arkiv:subset": "pnpm --filter @arkiv-search/indexer run arkiv:subset",
    "publish:arkiv": "pnpm --filter @arkiv-search/server run publish:arkiv",
    "cleanup:arkiv": "pnpm --filter @arkiv-search/server run cleanup:arkiv",
    "update-manifest": "pnpm --filter @arkiv-search/server run update-manifest",
    "smoke:arkiv": "pnpm --filter @arkiv-search/server run smoke:arkiv",
    "dev": "pnpm --filter @arkiv-search/client run dev"
  },
  "engines": {
    "node": ">=20"
  }
}
